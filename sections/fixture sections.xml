				<record id="phsn"/>
			</list>
		</record>
		<record id="pamT" collapsed="false">
			<translation id="text" translation_id="329730" type="use" value="Away Team Selection[COMMENT: sections.xml; match screen indicator text, matchday squad selection]" />
			<list id="items">
				<!--overview-->
				<record id="patc"/>

<!-- a popup button used to display role information -->
<class class="player_style_table_popup_button" parent="player_style_popup_button">
	<symbol id="widget_type" value="text"/>
	<record id="widget_properties">
		<integer id="width" value="260"/>
		<boolean id="multiline" value="true"/>
		<flags id="auto_size" value="vertical"/>
	</record>

	<record id="table_properties">
		<flags id="mode" value="fill_rows,stripe_rows,select_rows,dont_allow_click_unselect_single,hide_headings" />
		<integer id="row_height" value="28" />
		<integer id="row_spacing" value="1" />

		<list id="column_table_properties">
			<!--first column is some text-->
			<record>
				<flags id="id" value="plst" />
				<flags id="width" value="130" />
				<integer id="left" value="5" />
				<record id="widget_info">
					<symbol id="class" value="text" />
					<flags id="appearance" value="buttons/subtle/normal/button" />
					<record id="primary_icon_properties" red_replacement="text" />
					<flags id="font" value="text" />
				</record>
				<record id="column_widget_properties">
					<flags id="alignment" value="left,centre_y" />
				</record>

			</record>

		</list>
	</record>
</class>
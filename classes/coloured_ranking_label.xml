<!-- an action button that will be used in the news response panels -->

<!-- setting the 'icon' property on this should change the root folder for the appearance used to indicate checked states. icon="checkbox" would be the default -->
<class class="coloured_ranking_label" parent="number_label" colour="white" alignment="centre" format="[%number#1-nth]">
  <list id="value_list">
    <record min_value="-1" max_value="0" background_colour="neutral" />
    <record min_value="1" max_value="3" background_colour="positive" />
    <record min_value="4" max_value="5" background_colour="neutral" />
    <record min_value="6" max_value="11" background_colour="negative" />
  </list>
</class>
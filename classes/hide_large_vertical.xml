<!-- An attachment which will hide the widget unless the screen size is > then the min_value set -->
<class class="hide_large_vertical" parent="test_screen_size_attachment">
	<list id="properties">
		<record>
			<flags id="alignment" value="vertical" />
			<integer id="min_value" value="1200" />
			<integer id="max_value" value="100000" /> <!-- This is a very large value as we want our widget to show if > the min_value.  The attachmen itself only does values between a range so we set the max arbitrarily high to make this work -->
			<symbol id="set_property" value="hidden" />
		</record>
	</list>
</class>

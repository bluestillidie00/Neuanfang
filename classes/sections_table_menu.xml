<!-- a popup menu, with custom appearance for the breadcrumbs control -->
<class class="sections_table_menu" parent="modal_table_menu" file="modal table menu fixed height">
  <record id="table_properties">
    <flags id="mode" value="fill_rows,stripe_rows,select_rows,hide_headings,highlight_on_scroll" />
    <boolean id="auto_size_rows" value="false"/>
    <boolean id="fixed_size_rows" value="true"/>
    <integer id="row_spacing" value="1" />
    <integer id="row_height" value="36" />

    <list id="column_table_properties">
      <!--this column is just the regular text-->
      <record>
        <flags id="id" value="text" />
        <flags id="width" value="130" />
        <record id="widget_info">
          <symbol id="class" value="label" />
        </record>

        <record id="column_heading">
          <flags id="alignment" value="left,centre_y" />
        </record>
      </record>

      <!--this column is for the submenu arrow-->
      <record>
        <flags id="id" value="SubM" />
        <flags id="width" value="20" />
      </record>
    </list>
  </record>
</class>

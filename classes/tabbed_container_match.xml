<!-- A tabbed container is simply a multi-box with a tab strip as the top control -->
<class class="tabbed_container_match" parent="multi_box" contents_kind="plain_box" top_kind="tab_strip" appearance="boxes/tabbed/standard/paper">
      <flags id="top_layout" value="horizontal" />
      <record id="top_properties">
          <flags id="appearance" value="tabs/custom/match"/>
          <flags id="auto_size" value="vertical" />
          <flags id="alignment" value="top" />
          <boolean id="use_alt_end_tab_appearances" value="false"/>
      </record>
      <record id="group_properties">
          <flags id="appearance" value="boxes/tabbed/standard/paper" />
      </record>
</class>
